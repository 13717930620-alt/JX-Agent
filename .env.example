# ============================================
# HyperAgent 环境变量配置 (.env)
# 复制此文件为 .env 然后填写你的密钥
# ============================================

# ─── LLM 主适配器 ───
# 可选: deepseek / glm / minimax / qwen / mock
LLM_ADAPTER=deepseek

# ─── DeepSeek (或 Anthropic 兼容 API) ───
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ─── GLM (智谱) ───
# GLM_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4.7-flash

# ─── Qwen (通义千问) ───
# QWEN_API_KEY=
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

# ─── MiniMax ───
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_MODEL=MiniMax-Text-01

# ─── 多模型路由 ───
MULTI_MODEL_ENABLED=true
MULTI_MODEL_STRATEGY=balanced

# ─── Web 搜索 (Brave API) ───
# 获取: https://brave.com/search/api/
# BRAVE_API_KEY=BSA_xxx

# ─── 本地小模型 (Ollama) ───
LOCAL_INFERENCE_ENABLED=true
OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=qwen2.5:7b
LOCAL_EMBED_MODEL=nomic-embed-text

# ─── Embedding 模型 (v5.0 — 真实语义搜索) ───
# 模式: api (远程API) / local (本地BGE) / builtin (内置TF-IDF) / hybrid (混合)
EMBEDDING_MODE=hybrid
# API 模式配置 (OpenAI 兼容, 支持 text-embedding-3, jina-embeddings-v3, BGE API 等)
# EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
# EMBEDDING_API_KEY=sk-your-key-here
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
# EMBEDDING_BATCH_SIZE=20
# EMBEDDING_CACHE_SIZE=5000

# ─── 向量记忆 ───
VECTOR_STORE_ENABLED=true
VECTOR_STORE_MODE=hybrid
VECTOR_MAX_ITEMS=5000

# ─── 知识图谱 ───
KG_ENABLED=true
KG_AUTO_EXTRACT=true
KG_TEMPORAL=true

# ─── 跨会话记忆 ───
CROSS_SESSION_MEMORY=true
CROSS_SESSION_LOAD_COUNT=200

# ─── 对话状态机 ───
STATE_MACHINE_ENABLED=true

# ─── 任务分解 ───
TASK_DECOMPOSITION=true
CHECKPOINT_ENABLED=true
CHECKPOINT_AUTO_RESTORE=true

# ─── 人机协作 ───
HUMAN_IN_LOOP=true

# ─── 多智能体 ───
MULTI_AGENT_ENABLED=true
MULTI_AGENT_STRATEGY=sequential

# ─── GUI 自动化 ───
GUI_SCREENSHOT=true
GUI_INPUT=false   # 默认关闭，需要授权

# ─── 权限 ───
PERM_DEFAULT_LEVEL=info
PERM_SESSION_TIMEOUT=3600
PERM_CONFIRM_DANGEROUS=true

# ─── 承载体 ───
DEVICE_TYPE=pc
SAFETY_LEVEL=medium
STATE_COLLECT_INTERVAL=15000

# ─── 认知框架 ───
COGNITIVE_FRAMEWORK_ENABLED=true
COGNITIVE_DEBUG=false

# ─── 持续学习 ───
CONTINUAL_LEARNING_ENABLED=true

# ─── 监控 ───
LOG_LEVEL=info
METRICS_ENABLED=true
TRACING_ENABLED=true

# ─── UI-TARS GUI 自动化（字节跳动纯视觉桌面控制）───
UI_TARS_ENABLED=true
# UI-TARS 使用 Vision-Language 模型，需支持视觉输入
UI_TARS_MODEL=deepseek-v4-flash
UI_TARS_BASE_URL=https://api.deepseek.com
UI_TARS_API_KEY=
UI_TARS_MAX_LOOP=30
UI_TARS_ALLOW_MOUSE=true
UI_TARS_ALLOW_KEYBOARD=false   # 键盘输入默认关闭
UI_TARS_ALLOW_SCROLL=true
UI_TARS_MAX_CLICKS=30

# ─── Web 服务 ───
PORT=3000
# JINGXUANAGENT_AUTH_TOKEN=your_auth_token

# ─── 调试 ───
# DEBUG=true
# DEBUG_LLM=false
# DEBUG_TOOLS=false
# DEBUG_MEMORY=false

# ─── v4.0 全面升级配置 ───
# 记忆升级
UPGRADE_AUDN=true
UPGRADE_AUDN_BATCH=10
UPGRADE_AUDN_INTERVAL=120000
UPGRADE_MEMBLOCKS=true
UPGRADE_BITEMPORAL=true
UPGRADE_HIERARCHICAL_RAG=true

# 决策升级
UPGRADE_TOT=true
UPGRADE_SKILLS=true
UPGRADE_MCTS=false       # 高成本，默认关闭

# 交互升级
UPGRADE_GROUPCHAT=false   # 多智能体群聊，默认关闭
UPGRADE_GROUPCHAT_MODE=round_robin
UPGRADE_ADVERSARIAL=true
UPGRADE_ADVERSARIAL_DEPTH=quick
UPGRADE_PERSONA=true

# 感知与执行升级
UPGRADE_SCREEN=true
UPGRADE_CODEACT=false    # 代码执行模式，默认关闭
UPGRADE_DURABLE=true

